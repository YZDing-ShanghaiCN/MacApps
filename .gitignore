# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging and build outputs
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test, coverage, and type-check caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyright/

# Local environment files
.env
.env.*
!.env.example

# Logs and runtime files
*.log
*.pid

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Node artifacts, in case a web frontend is added later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
